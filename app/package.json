{
  "name": "wispr-flow-clone",
  "version": "0.1.0",
  "description": "Wispr Flow clone — push-to-talk voice dictation for macOS",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "build:helper": "swiftc native/wispr-helper.swift -o native/wispr-helper -framework Cocoa -framework AVFoundation",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:fast": "electron-builder --mac --dir"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.devnoyo0123.wispr-flow-clone",
    "productName": "Wispr Flow Clone",
    "asar": false,
    "files": [
      "src/**/*",
      "renderer/**/*",
      "native/wispr-helper",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Wispr Flow Clone",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
